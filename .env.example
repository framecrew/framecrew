# Copy this file to .env and fill in your values. Never commit .env.

# LLM API (OpenAI-compatible) — required for v0.1.0
OPENAI_API_KEY=
# Optional: override to use OpenRouter / Together / a local proxy / etc.
OPENAI_BASE_URL=https://api.openai.com/v1

# Telegram bot for the drop-and-confirm workflow (optional but recommended)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
